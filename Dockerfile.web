# Construye la PWA (Vite) y la sirve con Caddy, todo dentro de Docker.
# Tras la migración a Supabase, la app no tiene backend propio: soloStatics.
# Las VITE_SUPABASE_* y VITE_MAPTILER_KEY se hornean en el bundle en build.

# --- Etapa 1: build de la PWA ---
FROM node:22-alpine AS build
WORKDIR /app

# Dependencias primero (capa cacheable: solo se reinstala si cambia el lockfile).
COPY package.json package-lock.json ./
RUN npm ci

# Resto del código y build.
COPY . .
# Vite hornea las variables VITE_* en tiempo de build.
ARG VITE_MAPTILER_KEY=""
ENV VITE_MAPTILER_KEY=$VITE_MAPTILER_KEY
ARG VITE_SUPABASE_URL=""
ENV VITE_SUPABASE_URL=$VITE_SUPABASE_URL
ARG VITE_SUPABASE_ANON_KEY=""
ENV VITE_SUPABASE_ANON_KEY=$VITE_SUPABASE_ANON_KEY
RUN npm run build

# --- Etapa 2: servir con Caddy ---
# El dist/ queda horneado en la imagen (ya no se monta desde el host).
# El Caddyfile se sigue montando como volumen desde docker-compose.
FROM caddy:2-alpine
COPY --from=build /app/dist /srv
