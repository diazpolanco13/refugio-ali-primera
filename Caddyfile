# Caddy: HTTPS automático (Let's Encrypt) + PWA (estáticos).
# Tras la migración a Supabase ya no hay proxy a /api ni /ws: la PWA habla
# directo con Supabase (Postgres, Auth, Realtime, Storage) vía supabase-js.
{$DOMAIN} {
	encode gzip

	# PWA (archivos estáticos con fallback SPA a index.html).
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
