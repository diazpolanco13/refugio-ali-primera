# Copia este archivo a ".env" en el VPS y completa los valores.
# docker compose lo lee automáticamente.
#
# Tras la migración a Supabase ya no hay backend propio: la capa de datos
# vive en Supabase. Solo hace falta el dominio y las VITE_* (horneadas en el
# bundle de la PWA al construir la imagen).

# Dominio que apunta al VPS (Caddy sacará el certificado HTTPS solo).
DOMAIN=refugio.tu-dominio.com

# Opcional: clave gratuita de MapTiler para las bases "Satélite HD" / "Calles HD".
VITE_MAPTILER_KEY=

# Supabase (Postgres + Auth + Realtime + Storage). Imprescindible para que la
# app funcione: sin VITE_SUPABASE_URL y VITE_SUPABASE_ANON_KEY no hay login ni
# datos. Encuéntralas en Supabase → Project Settings → API.
VITE_SUPABASE_URL=https://xzwifkckkakldnzkdeby.supabase.co
VITE_SUPABASE_ANON_KEY=
