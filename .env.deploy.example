# Copia este archivo a ".env" en el VPS y completa los valores.
# docker compose lo lee automáticamente.

# Dominio que apunta al VPS (Caddy sacará el certificado HTTPS solo).
DOMAIN=refugio.tu-dominio.com

# Contraseña de PostgreSQL (elige una fuerte).
DB_PASSWORD=cambia-esta-contrasena

# Secreto para firmar los JWT (largo y aleatorio). Genera uno con:
#   openssl rand -base64 48
JWT_SECRET=pega-aqui-un-secreto-aleatorio-largo

# Usuario administrador inicial (se crea la primera vez).
ADMIN_USER=admin
ADMIN_PASSWORD=cambia-esta-contrasena-admin
