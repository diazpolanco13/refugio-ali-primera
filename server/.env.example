# Backend — copiar a .env para desarrollo local (opcional).
# Si NO defines DATABASE_URL, el servidor usa PGlite (Postgres en proceso, sin instalar nada).

# PORT=3001
# HOST=0.0.0.0

# Postgres real (producción). Si está presente, se usa en vez de PGlite.
# DATABASE_URL=postgres://refugio:CONTRASEÑA@localhost:5432/refugio

# Carpeta de datos de PGlite en local (déjalo vacío para memoria).
# PGLITE_DIR=./.data/pglite

# Secreto para firmar los JWT (¡cámbialo en producción!).
# JWT_SECRET=un-secreto-largo-y-aleatorio

# Admin inicial (solo se usa la primera vez, si no hay usuarios).
# ADMIN_USER=admin
# ADMIN_PASSWORD=admin1234

# Orígenes CORS permitidos (coma-separados). "*" solo para desarrollo.
# CORS_ORIGIN=https://tu-dominio.com
